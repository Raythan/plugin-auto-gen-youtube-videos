# =============================================================================
# TEMPLATE DE CHAVES — valores FICTICIOS (troque pelos reais).
# =============================================================================
# Como usar:
#   1. Copie este ficheiro para config/.env  OU  para .env na raiz do projeto.
#   2. Substitua cada valor ficticio pela chave real da conta correspondente.
#   3. Para VARIAS contas no mesmo provedor, use os ficheiros em config/secrets/
#      (copie os *.example.txt para *.txt sem .example) — ver secao "Ficheiros".
#
# Carregamento: primeiro .env (raiz), depois config/.env. O ambiente do SO tem prioridade.
# =============================================================================

# --- Gemini (roteiro CLI; nao usado para geracao de imagens) ---
# Opcao A: ficheiro com varias chaves Google (recomendado, igual rotacao do CLI)
GEMINI_KEYS_FILE=config/secrets/gemini_keys.txt
# Opcao B: uma ou varias chaves no .env (virgula = varias)
GEMINI_API_KEY=AIzaSyFICTICIA_GEMINI_CONTA1_abcdefghijklmnopqrst
GEMINI_API_KEYS=AIzaSyFICTICIA_GEMINI_CONTA2_uvwxyz123456,AIzaSyFICTICIA_GEMINI_CONTA3_789012

# --- Hugging Face (imagens + TTS OmniVoice/Parler via hf_chain em video_profiles.yaml) ---
# Token precisa de permissao "Make calls to Inference Providers" / Spaces.
HF_TOKEN=hf_FICTICIA_uma_conta_so_xxxxxxxxxxxxxxxxxxxx
DEEPAI_API_KEY=deepai-ficticia-11111111-2222-3333-4444-555555555555
FAL_KEY=fal-ficticia-aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee:xxxxxxxx
POLLINATIONS_API_KEY=pollinations-ficticia-chave-opcional-xxxxxxxx

# --- Imagens: varias chaves no .env (CSV, mesma rotacao que ficheiros) ---
# HF_API_KEYS=hf_conta1_xxx,hf_conta2_yyy
# DEEPAI_API_KEYS=chave1,chave2
# FAL_API_KEYS=chave1,chave2
# POLLINATIONS_API_KEYS=chave1,chave2

# --- Imagens: apontar para ficheiro de chaves (alternativa ao CSV acima) ---
# HF_KEYS_FILE=config/secrets/hf_keys.txt
# DEEPAI_KEYS_FILE=config/secrets/deepai_keys.txt
# FAL_KEYS_FILE=config/secrets/fal_keys.txt
# POLLINATIONS_KEYS_FILE=config/secrets/pollinations_keys.txt

# --- Ficheiros em config/secrets/ (copie os .example.txt -> .txt) ---
#   gemini_keys.txt      <- gemini_keys.example.txt   (roteiro CLI)
#   hf_keys.txt          <- hf_keys.example.txt
#   deepai_key.txt       <- uma chave por linha (ou deepai_keys.txt)
#   fal_keys.txt         <- fal_keys.example.txt (trial; depois pago)
#   pollinations_keys.txt <- pollinations_keys.example.txt (opcional; anonimo sem chave)
#
# Caminhos padrao ja definidos em config/pipeline.yaml -> image_gen.keys_files

# --- Runtime ---
PIPELINE_USE_GEMINI=true
PIPELINE_UPLOAD_YOUTUBE=true

# --- ImageMagick (legendas) ---
# IMAGEMAGICK_BINARY=C:/Program Files/ImageMagick-7.1.2-Q16-HDRI/magick.exe
